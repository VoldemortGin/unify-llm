# unify-llm 网关 — 生产部署 env 模板(隐藏 key 的 OpenAI 兼容代理网关)。
#
# 用法:  cp .env.gateway.example .env  &&  chmod 600 .env  &&  填入真实值
# 机密只走服务端 env(本文件 + compose 注入);绝不进镜像、绝不进 git、绝不出网关响应/日志。
# compose 的 environment 已固定 APP_ENV/APP_GATEWAY_CONFIG/APP_RATELIMIT_BACKEND/APP_REDIS_URL,
# 本文件主要提供「上游各 provider 真实 key」与默认 provider。

# 运行环境:production → 缺上游 key 直接硬失败(绝不静默回退 MockProvider)。
APP_ENV=production

# 网关默认/兜底 provider(具体路由仍以 gateway.yaml 的 model→provider 为准)。
APP_LLM_PROVIDER=deepseek

# ── 上游各厂商真实 key(按 gateway.yaml 里用到的 provider 填;未用到的留空即可)──
# 这些 key 由工厂在请求期从 env 取,绝不出现在任何网关响应/日志里。
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
DATABRICKS_API_KEY=
DATABRICKS_BASE_URL=

# ── 应用 key 表 + 模型路由的配置源(仅 sha256,非机密;compose 已挂载并固定本值)──
APP_GATEWAY_CONFIG=/app/configs/gateway.yaml

# ── 限流/预算共享态后端(横向扩容用 redis;compose 已注入,单机也可改 memory)──
APP_RATELIMIT_BACKEND=redis
APP_REDIS_URL=redis://redis:6379/0
